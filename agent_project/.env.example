# .env.example
# Copy to .env and edit.  Never commit .env to git.
#
# All values below are the defaults used when this file is absent.

# ── Ollama settings ──────────────────────────────────────────────────────────
# Available models (pull first with: ollama pull <name>)
#   qwen2.5:14b        — excellent reasoning, good for 16 GB RAM
#   llama3.2:11b       — fast, solid general purpose
#   deepseek-r1:14b    — strong at multi-step reasoning / math
#   mistral:7b         — lightweight, quick on 8 GB RAM
OLLAMA_MODEL=ollama/qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEMP=0.7
OLLAMA_MAX_TOKENS=4096

# ── (Optional) Separate model per agent ──────────────────────────────────────
# Uncomment and edit agents.py to read these if you want different models
# for different roles (e.g. a faster model for the writer).
# RESEARCHER_MODEL=ollama/qwen2.5:14b
# WRITER_MODEL=ollama/llama3.2:11b
